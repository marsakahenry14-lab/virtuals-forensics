# Environment configuration for ACP Forensic Indexer
# Copy this file to .env and set your values

# Base Mainnet RPC endpoint
# Public: https://mainnet.base.org (may rate-limit)
# Recommended: use a paid endpoint (Alchemy, QuickNode, Infura)
BASE_RPC_URL=https://mainnet.base.org

# Block range for the research dataset
# To reproduce the published dataset exactly, use these values
START_BLOCK=44427013
END_BLOCK=47718785
